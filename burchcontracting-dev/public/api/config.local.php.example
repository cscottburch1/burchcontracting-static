<?php
/**
 * Copy this file to config.local.php on the server and fill in your secret
 * key and SMTP credentials. config.local.php is gitignored — upload it once
 * via FTP/hPanel File Manager. Never commit real values from this file.
 */
return [
    'to_email' => 'estimates@burchcontracting.com',
    'from_email' => 'noreply@burchcontracting.com',
    'recaptcha_secret_key' => 'YOUR_RECAPTCHA_SECRET_KEY',
    'recaptcha_min_score' => 0.5,

    // SMTP (authenticated) — replaces PHP mail(), which shared hosting often
    // sends to spam or drops silently. Get these from your mailbox/hosting
    // provider's SMTP settings, not invented values.
    'smtp_host' => 'CHANGE_ME_SMTP_HOST',
    'smtp_port' => 587,
    'smtp_username' => 'CHANGE_ME_SMTP_USERNAME',
    'smtp_password' => 'CHANGE_ME_SMTP_PASSWORD',
    // 'tls' = STARTTLS, usually port 587. 'ssl' = implicit TLS, usually port 465.
    'smtp_secure' => 'tls',

    // CRM database (public/api/admin/) — Hostinger MySQL, created in hPanel
    // under Databases. db_name/db_user are the full prefixed names Hostinger
    // assigns (e.g. u123456789_crm), not just what you typed when creating
    // them. 'localhost' is correct for Hostinger shared hosting.
    'db_host' => 'localhost',
    'db_name' => 'CHANGE_ME_DB_NAME',
    'db_user' => 'CHANGE_ME_DB_USER',
    'db_password' => 'CHANGE_ME_DB_PASSWORD',

    // CRM admin login (public/api/admin/login.php). Generate the hash with:
    //   php -r "echo password_hash('your-password-here', PASSWORD_DEFAULT);"
    // Never put the plain password here — hash only.
    'admin_username' => 'CHANGE_ME_ADMIN_USERNAME',
    'admin_password_hash' => 'CHANGE_ME_ADMIN_PASSWORD_HASH',
];
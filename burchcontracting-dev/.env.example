# reCAPTCHA v3 site key (public, not secret). For local dev only — production
# uses the VITE_RECAPTCHA_SITE_KEY GitHub Actions secret (see LAUNCH-CHECKLIST.md
# #3 to confirm which key that holds and that it's registered for
# burchcontracting.com). This example value is NOT necessarily correct for any
# real domain — get a real site key from the Google reCAPTCHA admin console.
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY

# Server-side secret goes in public/api/config.local.php on Hostinger (not in git).